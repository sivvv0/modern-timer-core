{
  "name": "modern-timer-core",
  "version": "0.0.1",
  "description": "A comprehensive, feature-rich timer management system designed specifically for Discord.js bots. With support for both v13 and v14, this package provides enterprise-grade timer functionality with advanced features like persistence, metrics, retry logic, and parallel execution.",
  "main": "src/index.js",
  "types": "src/types/index.d.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "npm test && npm run build",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "example": "node examples/basic.js",
    "example:discord": "node examples/discord-bot.js"
  },
  "keywords": [
    "discord.js",
    "timer",
    "setInterval",
    "setTimeout",
    "setImmediate",
    "discord-v13",
    "discord-v14",
    "bot",
    "scheduler",
    "cron",
    "queue",
    "retry",
    "rate-limit"
  ],
  "author": "s1vann sivandev@tuta.io",
  "license": "MIT",
  "peerDependencies": {
    "discord.js": "^13.0.0 || ^14.0.0"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "events": "^3.3.0",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "discord.js": "^14.14.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sivvv0/modern-timer-core"
  },
  "bugs": {
    "url": "https://github.com/sivvv0/modern-timer-core/issues"
  },
  "homepage": "https://github.com/sivvv0/modern-timer-core#readme"
}
